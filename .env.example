OPENAI_API_KEY=tu_clave_aqui

# Carpeta de datos persistentes (SQLite + documentos subidos).
# En Render debe coincidir con el mountPath del disco persistente (ver render.yaml).
# En local, si se deja vacía, se usa la carpeta del proyecto.
DATA_DIR=

# Clave para poder ver (no solo restablecer) la contraseña original de cada
# usuario desde el modulo Administracion. Generarla una sola vez con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Usar la MISMA clave en local y en Render (variable de entorno, nunca en el repo).
# Si se deja vacia, el boton "Ver contrasena" queda deshabilitado pero el resto
# del sistema (incluido el login) sigue funcionando igual.
PASSWORD_ENCRYPTION_KEY=
